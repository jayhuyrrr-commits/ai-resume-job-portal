rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid is string && data.email is string && 
             data.role in ['user', 'admin'] &&
             data.keys().hasAll(['uid', 'email', 'role', 'createdAt', 'updatedAt']);
    }

    function isValidResume(data) {
      return data.userId is string && data.title is string && 
             data.personalInfo is map &&
             (data.skills is list && data.skills.size() <= 50) &&
             data.keys().hasAll(['userId', 'title', 'personalInfo', 'skills']);
    }

    function isValidJob(data) {
      return data.title is string && data.company is string && 
             data.category is string && data.type is string &&
             data.description is string && data.description.size() <= 5000;
    }

    // --- Match Groups ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'role']);
    }

    match /resumes/{resumeId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidResume(incoming());
      allow update: if isOwner(existing().userId) && isValidResume(incoming());
      allow delete: if isOwner(existing().userId);
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isAdmin() && isValidJob(incoming());
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && 
                    exists(/databases/$(database)/documents/jobs/$(incoming().jobId));
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }
  }
}
